# Luv2Shop — local secrets. Copy this file to ".env" and fill in your keys, then run ./run.sh.
# .env is gitignored, so your keys never get committed.

# --- Stripe (test mode — no real charges) -------------------------------------
# Get both from https://dashboard.stripe.com/test/apikeys  (toggle "Test mode" on).
# run.sh hands the publishable key to the frontend and the secret key to the backend automatically.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
