# =====================================================================
#  AWS App Runner deploy — THE ONE FILE TO EDIT.
#
#  Both `deploy/aws-setup.sh` (provisioning) and
#  `.github/workflows/deploy-aws.yml` (the deploy) read this file, so your
#  settings live in exactly one place — nothing to hand-edit in the workflow.
#
#  Only NON-SECRET config lives here (committed on purpose). The real secrets —
#  the deployer access key/secret and the DB password — go to GitHub Secrets;
#  `aws-setup.sh` pushes them for you with the `gh` CLI (or prints them).
#  The workflow DISCOVERS your AWS account id and the RDS endpoint at runtime,
#  so there are no repo variables to manage.
#
#  Quick start:
#    1. Set AWS_REGION below (us-east-1 default is fine for many).
#    2. Run:  bash deploy/aws-setup.sh
#    3. Actions -> "Deploy - AWS (App Runner)" -> Run workflow.
# =====================================================================

# --- Region -------------------------------------------------------------------
AWS_REGION=us-east-1

# --- RDS MySQL instance + database -------------------------------------------
# DB_INSTANCE is the RDS identifier the workflow queries for the live endpoint.
DB_INSTANCE=luv2shop-db
# RDS rejects hyphens in the initial DB name, so this one is hyphen-free.
DB_NAME=fullstackecommerce
DB_USER=ecommerceapp

# --- App Runner service names (also used as the ECR repo names) --------------
BACKEND_SERVICE=luv2shop-backend
FRONTEND_SERVICE=luv2shop-frontend

# --- Sizing (App Runner CPU is in vCPU units, memory in MB) ------------------
BACKEND_CPU=1024
BACKEND_MEMORY=2048
FRONTEND_CPU=512
FRONTEND_MEMORY=1024

# --- GitHub-Actions deployer IAM user (created by the setup script) ----------
DEPLOYER_USER=luv2shop-gh-deployer
