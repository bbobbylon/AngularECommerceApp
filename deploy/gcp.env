# =====================================================================
#  GCP Cloud Run deploy — THE ONE FILE TO EDIT.
#
#  Both `deploy/gcp-setup.sh` (provisioning) and
#  `.github/workflows/deploy-gcp.yml` (the deploy) read this file, so your
#  settings live in exactly one place — there is nothing to hand-edit in the
#  workflow YAML.
#
#  Only NON-SECRET config lives here (it is committed to git on purpose).
#  The two real secrets — the deployer service-account key and the DB
#  password — go into GitHub Secrets; `gcp-setup.sh` pushes them for you with
#  the `gh` CLI (or prints them to paste in).
#
#  Quick start:
#    1. Set GCP_PROJECT below to your Google Cloud project id (the only
#       required edit). Tweak the rest only if you want to.
#    2. Run:  bash deploy/gcp-setup.sh
#    3. Actions -> "Deploy - GCP (Cloud Run)" -> Run workflow.
#
#  Don't want your project id in git? Add `deploy/gcp.env` to .gitignore and
#  set these as GitHub repo *Variables* instead — the workflow falls back to
#  its built-in defaults and you override per-repo. Committing it is simplest.
# =====================================================================

# --- REQUIRED: your Google Cloud project id ----------------------------------
GCP_PROJECT=your-project-id

# --- Region for Cloud Run + Artifact Registry + Cloud SQL --------------------
GCP_REGION=us-central1

# --- Artifact Registry docker repo (created by the setup script) -------------
AR_REPO=luv2shop

# --- Cloud SQL instance NAME (not the project:region:name connection name) ---
CLOUD_SQL_INSTANCE=luv2shop-db
# Cheapest tier; bump to db-g1-small etc. for more headroom.
CLOUD_SQL_TIER=db-f1-micro

# --- Application database + user (Flyway migrates the empty DB on boot) ------
DB_NAME=full-stack-ecommerce
DB_USER=ecommerceapp

# --- Cloud Run service names -------------------------------------------------
BACKEND_SERVICE=luv2shop-backend
FRONTEND_SERVICE=luv2shop-frontend

# --- Sizing / scaling (scale-to-zero keeps idle cost ~nil) -------------------
BACKEND_MEMORY=1Gi
BACKEND_MAX_INSTANCES=4
FRONTEND_MEMORY=256Mi
FRONTEND_MAX_INSTANCES=4

# --- GitHub-Actions deployer service account (created by the setup script) ---
DEPLOYER_SA=gh-deployer
