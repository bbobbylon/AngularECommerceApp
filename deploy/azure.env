# =====================================================================
#  Azure Container Apps deploy — THE ONE FILE TO EDIT.
#
#  Both `deploy/azure-setup.sh` (provisioning) and
#  `.github/workflows/deploy-azure.yml` (the deploy) read this file, so your
#  settings live in exactly one place — nothing to hand-edit in the workflow.
#
#  Only NON-SECRET config lives here (committed on purpose). The real secrets —
#  the service-principal JSON and the DB password — go to GitHub Secrets;
#  `azure-setup.sh` pushes them for you with the `gh` CLI (or prints them).
#
#  Quick start:
#    1. Set ACR_NAME and MYSQL_SERVER below to GLOBALLY-UNIQUE names (they form
#       public DNS: <acr>.azurecr.io and <server>.mysql.database.azure.com).
#       Lowercase alphanumeric; ACR no hyphens, MySQL server may use hyphens.
#    2. Run:  bash deploy/azure-setup.sh
#    3. Actions -> "Deploy - Azure (Container Apps)" -> Run workflow.
# =====================================================================

# --- Resource group + region -------------------------------------------------
RESOURCE_GROUP=luv2shop-rg
LOCATION=eastus

# --- GLOBALLY-UNIQUE names you choose (must not collide with anyone's) -------
ACR_NAME=your-unique-acr-name
MYSQL_SERVER=your-unique-mysql-name

# --- Container Apps environment ----------------------------------------------
ENVIRONMENT=luv2shop-env

# --- Azure Database for MySQL ------------------------------------------------
DB_NAME=full-stack-ecommerce
DB_USER=ecommerceapp

# --- Container App names ------------------------------------------------------
BACKEND_SERVICE=luv2shop-backend
FRONTEND_SERVICE=luv2shop-frontend

# --- Scaling -----------------------------------------------------------------
MIN_REPLICAS=0
MAX_REPLICAS=3
